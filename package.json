{
  "name": "john-mingam-seo-mcp",
  "version": "1.0.0",
  "description": "Production-grade SEO MCP server for Entity SEO, technical SEO, and CMS automation",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "seo-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts --transport stdio",
    "start": "node dist/index.js",
    "start:stdio": "node dist/index.js --transport stdio",
    "start:http": "node dist/index.js --transport http",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --ext .ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "seo",
    "entity-seo",
    "schema",
    "wordpress",
    "shopify"
  ],
  "author": "John Mingam <contact@johnmingam.com>",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "axios": "^1.8.4",
    "dotenv": "^16.4.7",
    "ioredis": "^5.4.2",
    "lru-cache": "^11.0.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.27.0",
    "@typescript-eslint/parser": "^8.27.0",
    "eslint": "^9.22.0",
    "nock": "^14.0.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
